#include <stdio.h>

int main() {
    int n;
    printf("Nhap so luong phan tu cua mang: ");
    scanf("%d", &n);

    int mang[n];

    // Nhap du lieu cho mang
    for (int i = 0; i < n; i++) {
        printf("Nhap phan tu mang[%d]: ", i);
        scanf("%d", &mang[i]);
    }

    // Gan gia tri ban dau cua max va min la phan tu dau tien
    int max = mang[0];
    int min = mang[0];

    // Duyet mang de tim max va min thuc su
    for (int i = 1; i < n; i++) {
        if (mang[i] > max) {
            max = mang[i];
        }
        if (mang[i] < min) {
            min = mang[i];
        }
    }

    // In ket qua
    printf("\n--- KET QUA ---\n");
    printf("Phan tu lon nhat la: %d\n", max);
    printf("Phan tu nho nhat la: %d\n", min);

    return 0;
}